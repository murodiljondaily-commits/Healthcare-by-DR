# ============================================================
#  MediSelf — environment configuration
#  Copy this file to ".env" and adjust the values.
# ============================================================

# --- Server ---
# Port the FastAPI/uvicorn server listens on (you set this).
PORT=3000
# CORS origins (comma separated). For same-origin deploy you can leave default.
CORS_ORIGINS=*

# --- Database ---
# SQLite file path (relative to the backend directory) or any SQLAlchemy URL.
DATABASE_URL=sqlite:///./mediself.db

# --- JWT secrets (CHANGE THESE IN PRODUCTION!) ---
JWT_SECRET=change-this-access-secret-please
JWT_REFRESH_SECRET=change-this-refresh-secret-please
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=14

# --- OTP / Email verification ---
# Require email OTP on register/login. Recommended: true
REQUIRE_EMAIL_VERIFICATION=true
OTP_TTL_MIN=10
OTP_LENGTH=6

# --- SMTP (Gmail App Password) ---
# Leave SMTP_* empty to run in DEMO mode: the OTP code is returned in the
# API response (field "dev_otp") instead of being emailed — handy for testing.
# Fill these in to send real verification emails:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM=MediSelf <youraddress@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- DeepSeek AI ---
# Leave empty to use the built-in offline assistant (safe localized fallback).
# Add your key to enable real DeepSeek responses:
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Frontend ---
# Path to the built SPA (relative to backend dir). Default points to ../frontend/dist
FRONTEND_DIST=../frontend/dist

# --- Demo data ---
# Seed demo doctors + patients on first run.
SEED_DEMO_DATA=true
